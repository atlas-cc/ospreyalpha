<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OSPREY · The operating system for business operations.</title>
<meta name="description" content="Osprey is a full operating system for business operations. It embeds into your company, analyzes everything, fixes what's broken, builds what's missing, and improves every week. Not a chatbot. An operator.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,300..700&family=Space+Grotesk:wght@300..600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bone:#F4F1E8; --bone-1:#EFEBDF; --card:#FBF9F3;
  --ink:#15130E; --ink-dim:#4A453B; --ink-muted:#857D6E; --ink-faint:#C9C2B2;
  --talon:#C2470A; --talon-deep:#8F3206; --talon-pale:#E8B79B;
  --hair:rgba(21,19,14,.10); --hair-2:rgba(21,19,14,.22); --hair-talon:rgba(194,71,10,.3);
  --deck:#15130E; --deck-1:#1D1A13; --deck-ink:#F6F1E4; --deck-dim:#D3CAB6; --deck-muted:#A1977F; --deck-hair:rgba(246,241,228,.12); --deck-hair-2:rgba(246,241,228,.24);
  --sans:"Space Grotesk",ui-sans-serif,system-ui,sans-serif;
  --serif:"Fraunces",ui-serif,Georgia,serif;
  --mono:"IBM Plex Mono",ui-monospace,SFMono-Regular,Menlo,monospace;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--bone);color:var(--ink);font-family:var(--sans);font-weight:300;line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
::selection{background:var(--talon);color:var(--bone)}
.wrap{max-width:1320px;margin:0 auto;padding:0 56px}
@media(max-width:760px){.wrap{padding:0 24px}}

/* ---------- type ---------- */
.mono{font-family:var(--mono);font-size:11px;font-weight:500;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-muted)}
h1,h2,h3{font-family:var(--serif);font-weight:430;font-variation-settings:"opsz" 144;line-height:1.02;letter-spacing:-.015em}
.it{font-style:italic;color:var(--talon);font-weight:400}
.eyebrow{display:flex;align-items:center;gap:14px;font-family:var(--mono);font-size:11px;font-weight:500;letter-spacing:.24em;text-transform:uppercase;color:var(--ink-muted)}
.eyebrow::before{content:"";width:7px;height:7px;background:var(--talon);transform:rotate(45deg);flex:none}
a{color:inherit;text-decoration:none}
.link-line{font-family:var(--mono);font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:var(--ink);border-bottom:2px solid var(--talon);padding-bottom:10px;display:inline-flex;gap:14px;align-items:center;transition:color .3s}
.link-line:hover{color:var(--talon)}
.arrow{color:var(--talon);transition:transform .3s}
.link-line:hover .arrow{transform:translateX(6px)}
.btn-solid{font-family:var(--mono);font-size:12px;letter-spacing:.2em;text-transform:uppercase;background:var(--ink);color:var(--bone);padding:20px 36px;display:inline-flex;gap:14px;align-items:center;transition:background .3s}
.btn-solid:hover{background:var(--talon)}
.btn-solid .arrow{color:var(--talon)}
.btn-solid:hover .arrow{color:var(--bone)}

/* ---------- bird ---------- */
.bird{display:block;fill:currentColor}
.bird-hero{position:absolute;top:120px;right:-60px;width:min(54vw,760px);color:var(--ink);opacity:.05;pointer-events:none;transform:rotate(-6deg)}
@media(max-width:1080px){.bird-hero{display:none}}
.bird-final{width:64px;margin:0 auto 34px;color:var(--talon)}
.bird-mark{width:30px;color:var(--talon);flex:none}

/* ---------- reveal ---------- */
.rv{opacity:0;transform:translateY(26px);transition:opacity .9s cubic-bezier(.2,.6,.2,1),transform .9s cubic-bezier(.2,.6,.2,1)}
.rv.on{opacity:1;transform:none}
.rv.d1{transition-delay:.12s}.rv.d2{transition-delay:.24s}.rv.d3{transition-delay:.36s}

/* ---------- nav ---------- */
nav{position:fixed;inset:0 0 auto 0;z-index:50;backdrop-filter:blur(14px);background:rgba(244,241,232,.85);border-bottom:1px solid var(--hair)}
.nav-in{display:flex;align-items:center;justify-content:space-between;height:76px}
.brand{display:flex;align-items:center;gap:16px}
.brand .name{font-family:var(--serif);font-size:23px;letter-spacing:.3em;text-transform:uppercase;font-weight:500}
.brand .by{font-family:var(--mono);font-size:10px;letter-spacing:.3em;color:var(--ink-muted);border-left:1px solid var(--hair-2);padding-left:16px;text-transform:uppercase}
@media(max-width:760px){.brand .by{display:none}}

/* ---------- hero ---------- */
.hero{position:relative;padding:200px 0 130px;overflow:hidden;background:
  radial-gradient(1100px 600px at 82% -10%,rgba(194,71,10,.07),transparent 60%),
  linear-gradient(180deg,var(--bone-1),var(--bone) 40%)}
.hero-grid{position:relative;display:grid;grid-template-columns:1.05fr 1fr;gap:80px;align-items:center}
@media(max-width:1080px){.hero-grid{grid-template-columns:1fr}}
.hero h1{font-size:clamp(50px,5.8vw,92px);margin:36px 0 36px}
.hero .lead{font-size:18.5px;color:var(--ink-dim);max-width:560px;line-height:1.75}
.hero .lead strong{color:var(--ink);font-weight:500}
.hero-cta{margin-top:50px;display:flex;gap:36px;align-items:center;flex-wrap:wrap}
.hero-note{margin-top:40px;font-family:var(--mono);font-size:10px;letter-spacing:.22em;color:var(--ink-muted);text-transform:uppercase;line-height:2.1;max-width:420px}
.hero-note b{color:var(--talon);font-weight:500}

/* ---------- deck (dark command panels) ---------- */
.deck{background:linear-gradient(165deg,var(--deck-1),var(--deck));border-radius:12px;box-shadow:0 50px 100px rgba(21,19,14,.28);color:var(--deck-ink);overflow:hidden}
.deck-bar{display:flex;align-items:center;justify-content:space-between;padding:18px 26px;border-bottom:1px solid var(--deck-hair)}
.deck-bar .l{display:flex;align-items:center;gap:14px;font-family:var(--mono);font-size:10px;letter-spacing:.26em;text-transform:uppercase;color:var(--deck-muted)}
.deck-bar .l .nm{color:var(--deck-ink);font-family:var(--serif);font-size:14px;letter-spacing:.3em;font-weight:500}
.live{display:flex;align-items:center;gap:10px;font-family:var(--mono);font-size:10px;letter-spacing:.24em;color:var(--deck-dim);text-transform:uppercase}
.live b{color:var(--talon);font-weight:500}
.live b::before{content:"";display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--talon);margin-right:8px;animation:pulse 2.2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.25}}
.deck-greet{display:flex;justify-content:space-between;gap:30px;padding:28px 26px 24px;border-bottom:1px solid var(--deck-hair)}
.deck-greet h3{font-size:clamp(23px,2.1vw,29px);line-height:1.28;font-weight:380;letter-spacing:0;color:var(--deck-ink)}
.deck-greet .meta{font-family:var(--mono);font-size:9.5px;letter-spacing:.2em;text-transform:uppercase;color:var(--deck-dim);text-align:right;line-height:2.2;flex:none}
.dstats{display:grid;grid-template-columns:1fr 1fr 1fr;border-bottom:1px solid var(--deck-hair)}
.dstats .cell{padding:22px 26px;border-right:1px solid var(--deck-hair)}
.dstats .cell:last-child{border-right:0}
.dstats .k{font-family:var(--mono);font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--deck-dim);line-height:1.9}
.dstats .v{font-family:var(--serif);font-size:clamp(26px,2.4vw,37px);margin:9px 0 7px;font-weight:430;color:var(--deck-ink)}
.dstats .v small{font-family:var(--mono);font-size:10px;letter-spacing:.18em;color:var(--deck-dim)}
.dstats .v.t{color:var(--talon);font-style:italic}
.dstats .sub{font-family:var(--mono);font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--deck-muted)}
.dstats .sub.up{color:var(--talon)}
.dledg-h{display:flex;justify-content:space-between;align-items:center;padding:18px 26px 6px}
.dledg-h .t{font-family:var(--mono);font-size:10px;letter-spacing:.24em;text-transform:uppercase;color:var(--deck-ink)}
.dledg-h .t::before{content:"◆ ";color:var(--talon);font-size:8px}
.dledg-h a{font-family:var(--mono);font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--deck-muted)}
.dledg-h a:hover{color:var(--talon)}
.drow{display:flex;align-items:baseline;gap:16px;padding:12px 26px;border-top:1px solid var(--deck-hair);font-size:13.5px}
.drow:first-of-type{border-top:0}
.drow .tm{font-family:var(--mono);font-size:10.5px;color:var(--deck-muted);flex:none;width:42px}
.drow .who{color:var(--talon);font-weight:400;flex:none}
.drow .what{color:var(--deck-dim);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1}
.drow .tag{font-family:var(--mono);font-size:8.5px;letter-spacing:.18em;text-transform:uppercase;color:var(--deck-muted);flex:none}

/* ---------- sections ---------- */
section{position:relative;padding:140px 0;border-top:1px solid var(--hair)}
.sec-grid{display:grid;grid-template-columns:300px 1fr;gap:90px}
@media(max-width:1080px){.sec-grid{grid-template-columns:1fr;gap:44px}}
.sec-label{font-family:var(--mono);font-size:11px;letter-spacing:.26em;text-transform:uppercase;color:var(--ink-muted);position:sticky;top:120px;align-self:start;line-height:2}
.sec-label .n{color:var(--talon)}
.bigp{font-family:var(--serif);font-size:clamp(30px,3.2vw,46px);font-weight:400;line-height:1.28;letter-spacing:-.01em;max-width:880px}
.bigp .dim{color:var(--ink-muted)}
.statrow{display:grid;grid-template-columns:repeat(3,1fr);margin-top:80px;border-top:2px solid var(--ink)}
.statrow .s{padding:34px 36px 0 0;border-right:1px solid var(--hair)}
.statrow .s:last-child{border-right:0}
.statrow .s:nth-child(n+2){padding-left:36px}
.statrow .num{font-family:var(--serif);font-size:clamp(42px,4.2vw,66px);line-height:1;font-weight:430}
.statrow .num.t{color:var(--talon);font-style:italic}
.statrow .num small{font-family:var(--mono);font-size:13px;letter-spacing:.18em;color:var(--ink-muted)}
.statrow .cap{font-family:var(--mono);font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-muted);margin-top:18px;line-height:2}
@media(max-width:860px){.statrow{grid-template-columns:1fr}.statrow .s{border-right:0;border-bottom:1px solid var(--hair);padding:28px 0}}

/* ---------- protocol loop ---------- */
.loop{display:grid;grid-template-columns:repeat(4,1fr);margin-top:80px;border:1px solid var(--hair-2);background:#fff}
@media(max-width:980px){.loop{grid-template-columns:1fr 1fr}}
@media(max-width:560px){.loop{grid-template-columns:1fr}}
.loop .ph{padding:44px 36px 40px;border-right:1px solid var(--hair-2);position:relative}
.loop .ph:last-child{border-right:0}
@media(max-width:980px){.loop .ph{border-bottom:1px solid var(--hair-2)}}
.loop .ph .n{font-family:var(--mono);font-size:10px;letter-spacing:.24em;color:var(--talon);text-transform:uppercase}
.loop .ph h3{font-size:clamp(28px,2.6vw,40px);margin:20px 0 16px;font-weight:480}
.loop .ph p{color:var(--ink-dim);font-size:14.5px;line-height:1.75}
.loop .ph .arr{position:absolute;right:-9px;top:50%;transform:translateY(-50%);z-index:2;color:var(--talon);font-size:15px;background:#fff;line-height:1}
@media(max-width:980px){.loop .ph .arr{display:none}}

/* ---------- versus ---------- */
.versus{display:grid;grid-template-columns:1fr 1fr;border:1px solid var(--hair-2);overflow:hidden;margin-top:70px}
@media(max-width:860px){.versus{grid-template-columns:1fr}}
.versus .col{padding:48px 44px}
.versus .col.a{background:#fff;border-right:1px solid var(--hair-2)}
.versus .col.b{background:var(--deck);color:var(--deck-ink)}
@media(max-width:860px){.versus .col.a{border-right:0;border-bottom:1px solid var(--hair-2)}}
.versus .tag{font-family:var(--mono);font-size:10px;letter-spacing:.26em;text-transform:uppercase;margin-bottom:26px}
.versus .col.a .tag{color:var(--ink-muted)}
.versus .col.b .tag{color:var(--talon)}
.versus h3{font-size:clamp(24px,2.2vw,32px);margin-bottom:26px;font-weight:450}
.versus .col.a h3 .ghost{color:var(--ink-muted);font-style:italic}
.versus .col.b h3{color:var(--deck-ink)}
.versus ul{list-style:none}
.versus li{padding:15px 0;font-size:15px;display:flex;gap:16px}
.versus .col.a li{border-top:1px solid var(--hair);color:var(--ink-dim)}
.versus .col.b li{border-top:1px solid var(--deck-hair-2);color:var(--deck-dim)}
.versus li::before{font-family:var(--mono);font-size:11px;flex:none;margin-top:4px}
.versus .col.a li::before{content:"·";color:var(--ink-faint)}
.versus .col.b li::before{content:"◆";color:var(--talon);font-size:8px;margin-top:8px}
.exec-list{margin-top:64px}
.exec-list .hd{font-family:var(--mono);font-size:10px;letter-spacing:.24em;text-transform:uppercase;color:var(--ink-muted);margin-bottom:10px}
.exec-line{font-family:var(--serif);font-size:clamp(20px,1.9vw,26px);line-height:1.85;color:var(--ink-dim);font-weight:400}
.exec-line em{color:var(--talon);font-style:italic}
.exec-line .sep{color:var(--ink-faint);padding:0 12px}
.fact{margin-top:60px;padding:34px 40px;border-left:3px solid var(--talon);background:#fff;display:flex;gap:30px;align-items:flex-start}
@media(max-width:680px){.fact{flex-direction:column}}
.fact .f{font-family:var(--serif);font-style:italic;font-size:clamp(19px,1.8vw,24px);color:var(--ink)}
.fact .s{font-family:var(--mono);font-size:9.5px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-muted);margin-top:14px}

/* ---------- pillars ---------- */
.pillar{display:grid;grid-template-columns:110px 330px 1fr;gap:40px;padding:54px 0;border-top:1px solid var(--hair);align-items:start}
.pillar:first-of-type{border-top:0}
@media(max-width:1080px){.pillar{grid-template-columns:1fr;gap:14px;padding:40px 0}}
.pillar .no{font-family:var(--mono);font-size:10px;letter-spacing:.22em;color:var(--talon);text-transform:uppercase;line-height:2.2}
.pillar h3{font-size:clamp(26px,2.4vw,36px);line-height:1.12;font-weight:460}
.pillar .sub{font-family:var(--serif);font-style:italic;font-size:16px;color:var(--ink-muted);margin-top:10px;font-weight:400}
.pillar p{color:var(--ink-dim);font-size:15.5px;max-width:560px;line-height:1.8}
.pillar p b{color:var(--ink);font-weight:500}

/* ---------- fleet ---------- */
.org{margin-top:74px;border:1px solid var(--hair-2);background:#fff;padding:60px 40px 48px;position:relative}
.org-top{width:min(440px,90%);margin:0 auto;text-align:center;border:1px solid var(--hair-talon);padding:26px 30px;background:rgba(194,71,10,.06)}
.org-top .nm{font-family:var(--serif);font-size:22px;letter-spacing:.28em;text-transform:uppercase;font-weight:500}
.org-top .nm .mark{color:var(--talon);font-size:13px}
.org-top .rl{font-family:var(--mono);font-size:9.5px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-muted);margin-top:10px}
.org-stem{width:1px;height:44px;background:var(--hair-2);margin:0 auto}
.org-rail{height:1px;background:var(--hair-2);margin:0 7%}
.org-row{display:grid;grid-template-columns:repeat(5,1fr);gap:18px;padding:0 2%}
@media(max-width:1080px){.org-row{grid-template-columns:repeat(2,1fr)}.org-rail{display:none}.org-cell::before{display:none!important}}
@media(max-width:560px){.org-row{grid-template-columns:1fr}}
.org-cell{position:relative;border:1px solid var(--hair-2);padding:24px 20px;background:var(--bone);text-align:center;transition:border-color .3s,transform .3s}
.org-cell:hover{border-color:var(--talon);transform:translateY(-3px)}
.org-cell::before{content:"";position:absolute;top:-36px;left:50%;width:1px;height:36px;background:var(--hair-2)}
.org-cell .t{font-family:var(--serif);font-size:18px;line-height:1.2;font-weight:480}
.org-cell .d{font-family:var(--mono);font-size:9px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink-dim);margin-top:10px;line-height:1.9}
.keys{margin-top:64px}
.keys .hd{font-family:var(--mono);font-size:10px;letter-spacing:.24em;text-transform:uppercase;color:var(--ink-muted);margin-bottom:22px}
.keychips{display:flex;flex-wrap:wrap;gap:12px}
.keychips span{font-family:var(--mono);font-size:10.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink);border:1px solid var(--hair-2);background:#fff;padding:10px 20px;transition:border-color .3s,color .3s}
.keychips span:hover{border-color:var(--talon);color:var(--talon)}
.keys .note{font-family:var(--serif);font-style:italic;color:var(--ink-dim);font-size:18px;margin-top:26px;font-weight:400}
.keys .note em{color:var(--talon)}

/* ---------- timeline ---------- */
.tl-note{color:var(--ink-dim);font-size:16px;margin-top:26px;max-width:560px;line-height:1.8}
.tl{margin-top:66px}
.tl-row{display:grid;grid-template-columns:300px 1fr;gap:90px;padding:44px 0;border-top:1px solid var(--hair)}
@media(max-width:1080px){.tl-row{grid-template-columns:1fr;gap:16px}}
.tl-row .tm{font-family:var(--serif);font-size:34px;font-weight:430}
.tl-row .ag{font-family:var(--mono);font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-muted);margin-top:12px}
.tl-row .ag::before{content:"◆ ";color:var(--talon);font-size:8px}
.tl-row h3{font-size:clamp(22px,2vw,29px);font-weight:460}
.tl-row p{color:var(--ink-dim);font-size:15.5px;margin-top:16px;max-width:760px;line-height:1.8}
.tl-row .ft{font-family:var(--mono);font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-muted);margin-top:18px;display:flex;gap:26px;flex-wrap:wrap}
.tl-row .ft b{color:var(--talon);font-weight:500;font-size:13px;letter-spacing:.04em}

/* ---------- engagement ---------- */
.phase{display:grid;grid-template-columns:300px 1fr;gap:90px;padding:62px 0;border-top:1px solid var(--hair)}
.phase:first-of-type{border-top:0}
@media(max-width:1080px){.phase{grid-template-columns:1fr;gap:18px;padding:44px 0}}
.phase .ph{font-family:var(--mono);font-size:10px;letter-spacing:.26em;text-transform:uppercase;color:var(--talon)}
.phase h3{font-size:clamp(30px,3vw,44px);font-weight:450}
.phase p{color:var(--ink-dim);font-size:16px;margin-top:22px;max-width:520px;line-height:1.85}
.phase .wk{font-family:var(--mono);font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-muted);margin-top:30px;padding-top:24px;border-top:1px dashed var(--hair-2);max-width:520px}

/* ---------- expansions ---------- */
.exp-grid{display:grid;grid-template-columns:1fr 1fr;margin-top:70px;border-top:1px solid var(--hair-2);border-left:1px solid var(--hair-2)}
@media(max-width:900px){.exp-grid{grid-template-columns:1fr}}
.exp{padding:50px 48px;border-right:1px solid var(--hair-2);border-bottom:1px solid var(--hair-2);background:#fff;transition:background .3s}
.exp:hover{background:var(--card)}
.exp .tag{font-family:var(--mono);font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-muted);margin-bottom:24px}
.exp .tag::before{content:"◆ ";color:var(--talon);font-size:8px}
.exp h3{font-size:clamp(24px,2.2vw,32px);font-weight:460}
.exp p{color:var(--ink-dim);font-size:15px;margin-top:18px;line-height:1.8}
.exp .sc{font-family:var(--mono);font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--ink-muted);margin-top:30px;padding-top:20px;border-top:1px dashed var(--hair-2)}

/* ---------- OS ---------- */
.os-head{text-align:center;max-width:860px;margin:0 auto}
.os-head h2{font-size:clamp(38px,4.4vw,64px);margin-top:34px}
.os-head p{color:var(--ink-dim);font-size:17px;margin:30px auto 0;max-width:620px;line-height:1.8}
.os-chips{display:flex;justify-content:center;gap:12px;margin-top:38px;flex-wrap:wrap}
.os-chips span{font-family:var(--mono);font-size:10.5px;letter-spacing:.2em;text-transform:uppercase;color:var(--ink-dim);border:1px solid var(--hair-2);background:#fff;padding:10px 22px}
.os-chips span.hot{color:var(--talon);border-color:var(--hair-talon)}
.mock-wrap{margin-top:90px}
.mock-cap{font-family:var(--mono);font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-muted);text-align:center;margin-top:26px}
.mock-cap b{color:var(--talon);font-weight:500}
